RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# next export can emit both `foo.html` and a `foo/` metadata directory.
# On Apache static hosting, requesting `/foo` can hit the directory first and
# return 403 when it has no index.html. Prefer the sibling HTML file instead.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
